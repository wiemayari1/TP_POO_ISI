package com.java.ex7;

public class Cercle extends Point {
    public double rayon;
    
    public Cercle(int x, int y, double rayon) {
        super(x, y);
        this.rayon = rayon;
    }
    
    public double surface() {
        return 3.14 * rayon * rayon;
    }
    
    public void affiche() {
        System.out.printf("Je suis un cercle de surface %.2f%n", surface());
    }
}
