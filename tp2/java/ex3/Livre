package com.java.ex3;

public class Livre extends Document{
	String auteur;
	int nbpage;
	
	public Livre(int num, String titre, String auteur, int nbpage) {
		super(num,titre);
		this.auteur=auteur;
		this.nbpage=nbpage;
	}
	
	public String getAuteur() {
        return auteur;
    }
    
    public int getNbpage() {
        return nbpage;
    }
    
    public void setAuteur(String auteur) {
        this.auteur=auteur;
    }
    
    public void getNbpage(int nbpage) {
        this.nbpage=nbpage;
    }
    
    @Override
    public String toString() {
        return "Document [auteur=" + auteur + ", nbpage=" + nbpage + "]";
    }

}
